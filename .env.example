# ============================================================================
# scholar-agent configuration  (copy to .env and edit)
# ============================================================================
# Everything talks an OpenAI-compatible API, so the "brains" can be vLLM,
# Ollama, TGI, or a hosted endpoint — the orchestrator does not care.

# --- Model serving (the air-gapped "Brains" VMs behind PCIe passthrough) ---
# Point these at your vLLM / Ollama servers. They never touch the internet.
# Local Ollama example: http://localhost:11434/v1  (LLM_API_KEY=ollama)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=changeme                       # placeholder — put real keys only in .env (gitignored)

# --- Provider pool keys (used by providers.json; see providers.json.example) ---
# Referenced by name via each provider's "api_key_env". Fill only what you use.
# OLLAMA_API_KEY=ollama                    # value ignored, but the SDK needs it non-empty
# GROQ_API_KEY=                            # free key: https://console.groq.com/keys
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=

# Tiered model matrix (see src/scholar/llm/router.py). Override per role.
MODEL_HEAVY=Qwen2.5-72B-Instruct          # Orchestrator + Quality Gate
MODEL_FAST=Mistral-Nemo-12B-Instruct       # Profiler + Scout (JSON / tools)
MODEL_SCRIBE=Qwen2.5-32B-Instruct          # Document synthesis
EMBED_MODEL=BAAI/bge-large-en-v1.5         # served via fastembed locally
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2 # must be a fastembed-supported reranker

# --- Knowledge base ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=opportunities

# --- Scout tools (the "Hands" container — this one HAS internet) ---
TAVILY_API_KEY=                            # optional; falls back to SearXNG
SEARXNG_URL=http://searxng:8080
OPENALEX_MAILTO=you@example.com            # polite pool, higher rate limits
# NSF / NIH are public, no key required.
HF_TOKEN=                                  # optional; faster local model downloads

# --- Observability (open-source) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# --- Pipeline tuning ---
MAX_REFLECTION_LOOPS=3                      # Scribe <-> Quality Gate retries
MATCH_SCORE_THRESHOLD=70                    # only synthesise above this score
TOP_K_OPPORTUNITIES=5
LOG_LEVEL=INFO

# --- Deep research ---
DEEP_BREADTH=5                             # search sub-questions per round
DEEP_DEPTH=2                               # plan + reflect-and-expand rounds
DEEP_MAX_PAGES=10                          # pages harvested per round
CRITIC_MAX_ENRICH=3                        # targeted searches to fill missing deadlines (0=off)
# Recursive crawling (needs crawl4ai + a headless browser — GPU/desktop only):
DEEP_CRAWL_DEPTH=0                         # 0=single-page (default); 1-3 follows links deeper
DEEP_CRAWL_MAX_PAGES=8                     # cap pages per seed URL when deep-crawling
